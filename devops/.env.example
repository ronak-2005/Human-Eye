# ============================================================
# HumanEye — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# ── General ───────────────────────────────────────────────
ENV=development                        # development | staging | production
APP_NAME=humaneye

# ── Backend (FastAPI) ─────────────────────────────────────
# NEED FROM DEVOPS: PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://humaneye:CHANGE_ME@localhost:5432/humaneye

# NEED FROM DEVOPS: TimescaleDB connection string
TIMESCALE_URL=postgresql+asyncpg://humaneye:CHANGE_ME@localhost:5433/humaneye_signals

# NEED FROM DEVOPS: Redis connection string
REDIS_URL=redis://localhost:6379/0

# NEED FROM BACKEND ENG: Generate a strong random key (openssl rand -hex 32)
SECRET_KEY=CHANGE_ME

# NEED FROM BACKEND ENG: Which origins to allow CORS
ALLOWED_ORIGINS=http://localhost:3000

# NEED FROM DEVOPS: Internal ML engine URL
ML_ENGINE_URL=http://localhost:8001

# ── ML Engine ─────────────────────────────────────────────
# All variables below are per ML engineer specification

# Port (internal only — never exposed to internet)
ML_ENGINE_PORT=8001

# Workers (2 for Phase 1 CPU, scale up in Phase 2 GPU)
ML_ENGINE_WORKERS=2

# MLflow tracking server URL
ML_TRACKING_URI=http://mlflow:5000

# HuggingFace Transformers model cache directory
TRANSFORMERS_CACHE=/app/.cache/huggingface

# Saved model directory (must be a persistent volume in production)
MODEL_DIR=/app/ml_engine/saved_models

# Log level — ML logs structured JSON to stdout (CloudWatch ships it)
# ML never logs raw signal values — only metadata (session_id, score ranges, flags)
LOG_LEVEL=INFO

# Runtime environment
ENVIRONMENT=development          # development | staging | production

# NEED FROM DEVOPS: S3 bucket name for model storage
S3_BUCKET=humaneye-models-dev

# NEED FROM DEVOPS: TimescaleDB connection string (behavioral signals)
TIMESCALE_URL=postgresql+asyncpg://humaneye:CHANGE_ME@localhost:5433/humaneye_signals

# NEED FROM DEVOPS: Redis connection string (ML engine uses db index 1)
REDIS_URL=redis://localhost:6379/1

# ── Dashboard (Next.js) ───────────────────────────────────
# NEED FROM DEVOPS: Public API URL (must be accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# NEED FROM DEVOPS: WebSocket URL for real-time verification feed
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Vault (secrets management) ────────────────────────────
# NEED FROM DEVOPS: Vault server address
VAULT_ADDR=http://localhost:8200

# NEED FROM DEVOPS: Vault token (use AppRole in production, not root token)
VAULT_TOKEN=CHANGE_ME

# ── AWS ───────────────────────────────────────────────────
# NEED FROM DEVOPS: AWS credentials (use IAM roles in production, not keys)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1

# ── Third-party APIs (NEED FROM RELEVANT ROLE) ────────────

# NEED FROM SECURITY ENG: iProov liveness API (Phase 1 basic liveness)
IPROOV_API_KEY=CHANGE_ME
IPROOV_SECRET=CHANGE_ME

# NEED FROM BACKEND ENG: Plaid open banking (document verification)
PLAID_CLIENT_ID=CHANGE_ME
PLAID_SECRET=CHANGE_ME
PLAID_ENV=sandbox          # sandbox | development | production

# NEED FROM BACKEND ENG: Stripe (payment processing for subscription billing)
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME

# NEED FROM BACKEND ENG: MaxMind IP geolocation
MAXMIND_LICENSE_KEY=CHANGE_ME

# NEED FROM BACKEND ENG: Sendgrid (transactional emails)
SENDGRID_API_KEY=CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@humaneye.io

# NEED FROM BACKEND ENG: AWS Textract (document OCR — built in via AWS IAM)
# No extra key needed — uses ECS task IAM role

# ── Observability ─────────────────────────────────────────
# NEED FROM DEVOPS: OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Blockchain / ZK (Phase 3 only) ────────────────────────
# NEED FROM ZK ENG: Polygon RPC URL
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/CHANGE_ME
POLYGON_PRIVATE_KEY=CHANGE_ME

# ── Pinecone (vector search for behavioral fingerprinting) ─
# NEED FROM ML ENG: Pinecone API key
PINECONE_API_KEY=CHANGE_ME
PINECONE_ENV=us-east-1-aws
PINECONE_INDEX=humaneye-behavioral

# ── Neo4j (social graph — Phase 2) ────────────────────────
# NEED FROM DEVOPS: Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME
