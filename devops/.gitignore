# ── Secrets — NEVER commit these ─────────────────────────
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
terraform.tfvars          # contains db_password etc
!staging.tfvars            # these are safe (no secrets)
!production.tfvars         # these are safe (no secrets)
.terraform/                # downloaded providers
*.tfstate                  # state is in S3 backend
*.tfstate.backup
tfplan.*

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.mypy_cache/

# ── Node ──────────────────────────────────────────────────
node_modules/
.next/
.nuxt/
dist/
.cache/
*.tsbuildinfo

# ── ML models — stored in S3, not git ────────────────────
ml_engine/saved_models/*.pt
ml_engine/saved_models/*.onnx
ml_engine/saved_models/*.bin
ml_engine/saved_models/.torch_cache/
mlruns/

# ── Docker ────────────────────────────────────────────────
.dockerignore

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ───────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
