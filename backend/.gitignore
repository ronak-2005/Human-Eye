# HumanEye — .gitignore

# Environment — NEVER commit
.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Node
node_modules/
.next/
out/
npm-debug.log*

# Docker volumes (local data)
postgres_data/
timescale_data/
redis_data/
mlflow_data/
grafana_data/

# ML models (large binary files — store in S3/MLflow)
*.pt
*.pth
*.onnx
*.pkl
saved_models/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Secrets
*.pem
*.key
*.cert
vault-data/
