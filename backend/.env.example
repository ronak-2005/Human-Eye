# HumanEye — Environment Variables Template
# Copy to .env: cp .env.example .env
# Real values are injected by DevOps via AWS Secrets Manager in staging/production.
# For local dev fill in the values below.

APP_ENV=development
DEBUG=true
SECRET_KEY=                          # DevOps generates: openssl rand -hex 32

DATABASE_URL=postgresql+asyncpg://humaneye:humaneye_dev@postgres:5432/humaneye
TIMESCALE_URL=postgresql+asyncpg://humaneye:humaneye_dev@timescaledb:5432/humaneye_signals
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

ML_ENGINE_URL=http://ml_engine:8001  # underscore for docker-compose, hyphen for ECS
ML_TIMEOUT_MS=5000

BCRYPT_ROUNDS=12
MAX_PAYLOAD_BYTES=10485760

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token           # AppRole in production — DevOps sets this

# Week 3 — get from Stripe dashboard, send to DevOps via secure channel
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=

# Phase 2 — get from respective dashboards
PLAID_CLIENT_ID=
PLAID_SECRET=
MAXMIND_LICENSE_KEY=
IPROOV_API_KEY=

SENTRY_DSN=
