# ============================================================
# HumanEye Dashboard — Environment Variables
# Copy to .env.local for development. Never commit .env.local.
# ============================================================

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (ws:// for local, wss:// for prod)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---- Production overrides (set in deployment environment) ----
# NEXT_PUBLIC_API_URL=https://api.humaneye.io
# NEXT_PUBLIC_WS_URL=wss://api.humaneye.io
